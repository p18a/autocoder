{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "warn",
				"noUnusedVariables": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"files": {
		"includes": ["src/**", "*.json", "*.ts", "!node_modules", "!dist", "!data", "!bun.lock"]
	},
	"css": {
		"parser": { "tailwindDirectives": true },
		"linter": { "enabled": true },
		"formatter": { "enabled": true }
	}
}
